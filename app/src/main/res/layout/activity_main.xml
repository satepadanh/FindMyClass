<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DDEFF0">

    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/imgMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/kampus_master"
            android:scaleType="fitXY" />

        <FrameLayout
            android:id="@+id/markerGku1"
            android:layout_width="48dp"
            android:layout_height="64dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_marker_pin" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="GKU 1"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/markerGku2"
            android:layout_width="48dp"
            android:layout_height="64dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_marker_pin" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="GKU 2"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />
        </FrameLayout>

    </FrameLayout>

    <!-- Search bar -->
    <LinearLayout
        android:id="@+id/searchContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_search"
        android:elevation="6dp"
        android:padding="8dp">

        <AutoCompleteTextView
            android:id="@+id/searchBar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Ruangan apa yang Anda cari?"
            android:background="@android:color/transparent"
            android:singleLine="true"
            android:completionThreshold="1" />

        <TextView
            android:id="@+id/btnMenuRoom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="☰"
            android:textColor="#6A9FA4"
            android:textSize="28sp"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <!-- Card bawah -->
    <LinearLayout
        android:id="@+id/infoCard"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_card"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/txtGedung"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GKU 2"
            android:textColor="#222222"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="K2.9653-K2.9657, Indomaret, Kantin"
            android:textColor="#777777"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="200 meter lagi"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>