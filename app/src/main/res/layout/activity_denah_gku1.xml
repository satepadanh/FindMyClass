<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/denahRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF0">

    <!-- Tombol back -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="36dp"
        android:gravity="center"
        android:text="&#8249;"
        android:textColor="#111111"
        android:textSize="42sp" />

    <!-- Judul lantai -->
    <TextView
        android:id="@+id/txtTitleDenah"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="56dp"
        android:text="GKU 1 - Lantai 1"
        android:textColor="#111111"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Container denah + marker -->
    <FrameLayout
        android:id="@+id/floorMapContainer"
        android:layout_width="290dp"
        android:layout_height="290dp"
        android:layout_gravity="center"
        android:layout_marginTop="-80dp">

        <ImageView
            android:id="@+id/imgFloorMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/gku1_lt1" />

        <ImageView
            android:id="@+id/imgUserMarker"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/marker_user_dalam"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Status ESP -->
    <TextView
        android:id="@+id/txtEspStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="140dp"
        android:text="Mencari sinyal ESP..."
        android:textColor="#111111"
        android:textSize="12sp" />

    <!-- Group tombol lantai -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_floor_group"
        android:orientation="horizontal"
        android:padding="6dp">

        <TextView
            android:id="@+id/btnLt1"
            android:layout_width="52dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_floor_selected"
            android:gravity="center"
            android:text="L1"
            android:textColor="#111111"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnLt2"
            android:layout_width="52dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_floor_unselected"
            android:gravity="center"
            android:text="L2"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnLt3"
            android:layout_width="52dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_floor_unselected"
            android:gravity="center"
            android:text="L3"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnLt5"
            android:layout_width="52dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_floor_unselected"
            android:gravity="center"
            android:text="L5"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>
