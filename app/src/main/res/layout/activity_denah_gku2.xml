<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/denahRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF0">

    <TextView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="36dp"
        android:gravity="center"
        android:text="‹"
        android:textColor="#111111"
        android:textSize="42sp" />

    <TextView
        android:id="@+id/txtTitleDenah"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="160dp"
        android:text="GKU 2 - Lantai 1"
        android:textColor="#111111"
        android:textSize="16sp"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/floorMapContainer"
        android:layout_width="290dp"
        android:layout_height="290dp"
        android:layout_gravity="center"
        android:layout_marginTop="-40dp">

        <ImageView
            android:id="@+id/imgFloorMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/gku2_lt1" />

        <View
            android:id="@+id/pathLine"
            android:layout_width="6dp"
            android:layout_height="180dp"
            android:layout_gravity="end|top"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_path_line" />

        <ImageView
            android:id="@+id/imgUserMarker"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/marker_user_dalam" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/floorButtons"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:background="@drawable/bg_floor_group"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/btnLt5"
            style="@style/FloorButton"
            android:text="L5" />

        <TextView
            android:id="@+id/btnLt3"
            style="@style/FloorButton"
            android:text="L3" />

        <TextView
            android:id="@+id/btnLt2"
            style="@style/FloorButton"
            android:text="L2" />

        <TextView
            android:id="@+id/btnLt1"
            style="@style/FloorButton"
            android:text="L1" />

    </LinearLayout>

</FrameLayout>